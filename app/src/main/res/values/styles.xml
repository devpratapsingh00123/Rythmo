<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Card container style -->
    <style name="StatsCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:background">@drawable/card_background</item>
        <item name="android:padding">12dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Label text style (e.g., "Today", "Top Genre") -->
    <style name="StatsCardLabel">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <!-- Value text style (e.g., "4.2h", "Pop") -->
    <style name="StatsCardValue">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <!-- Fix: Missing CustomPopupMenu Style -->
    <style name="CustomPopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@android:color/black</item>
        <item name="android:textColor">@android:color/white</item>
    </style>


</resources>
