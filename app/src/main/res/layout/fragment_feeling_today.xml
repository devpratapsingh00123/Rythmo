<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_background_gradient"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How are you feeling today?"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"
            android:layout_gravity="start" />

        <GridLayout
            android:id="@+id/moodGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true">

            <!-- Mood 1: Happy -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageButton
                    android:id="@+id/emoji_happy"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/emoji_happy"
                    android:background="@android:color/transparent"
                    android:contentDescription="Happy"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Happy"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mood 2: Sad -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageButton
                    android:id="@+id/emoji_sad"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/emoji_sad"
                    android:background="@android:color/transparent"
                    android:contentDescription="Sad"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sad"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mood 3: Angry -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageButton
                    android:id="@+id/emoji_angry"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/emoji_angry"
                    android:background="@android:color/transparent"
                    android:contentDescription="Angry"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Angry"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mood 4: Romantic -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageButton
                    android:id="@+id/emoji_romantic"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/emoji_love"
                    android:background="@android:color/transparent"
                    android:contentDescription="Romantic"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Romantic"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mood 5: Relaxed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageButton
                    android:id="@+id/emoji_relaxed"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/emoji_relaxed"
                    android:background="@android:color/transparent"
                    android:contentDescription="Relaxed"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Relaxed"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mood 6: Energetic -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageButton
                    android:id="@+id/emoji_energy"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/emoji_energetic"
                    android:background="@android:color/transparent"
                    android:contentDescription="Energetic"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Energetic"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </GridLayout>
    </LinearLayout>
</ScrollView>
